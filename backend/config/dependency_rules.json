      "rule_id": "NON_APPLICABLE_FIELD_CLEANUP",
      "rule_type": "ui_internal_impact",
      "description": "When a field becomes not applicable, hide it from business UI and do not show dependent changes in Action Preview.",
      "priority": "CRITICAL",
      "when": {
        "all": [
          {
            "field": "field.applicable",
            "operator": "equals",
            "value": false
          }
        ]
      },
      "then": [
        {
          "field": "*",
          "effect": "HIDE_FROM_BUSINESS_UI",
          "value": true
        },
        {
          "field": "*",
          "effect": "KEEP_IN_INTERNAL_IMPACT_PLAN",
          "value": true
        },
        {
          "field": "*",
          "effect": "EXCLUDE_FROM_USER_FACING_ACTION_PREVIEW",
          "value": true
        }
      ],
      "else": [],
      "trace": {
        "source": "product_design",
        "business_reason": "Dependent changes are internal impacts and should not be shown directly to business users."
      }
